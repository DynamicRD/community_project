<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.project.admin.mapper.CommentAdminMapper">
	  <!-- 댓글 목록 조회 -->
    <select id="getComments" resultType="com.project.admin.model.CommentAdmin">
        SELECT * FROM comments ORDER BY reg_date DESC
    </select>

    <!-- 댓글 블라인드 처리 -->
    <update id="toggleBlind">
        UPDATE comments SET isblacked = 'Y' WHERE comments_no = #{no}
    </update>
	
	<!-- 댓글 블라인드 처리 Y->N -->
    <update id="toggleBlindYN">
        UPDATE comments SET isblacked = 'N' WHERE comments_no = #{no}
    </update>


</mapper>