<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.project.admin.mapper.NoticeAdminMapper">
	   <select id="getNotices" resultType="com.project.admin.model.NoticeAdmin">
        SELECT * FROM notice ORDER BY reg_date DESC
    </select>

    <select id="getNoticeById" resultType="com.project.admin.model.NoticeAdmin">
        SELECT * FROM notice WHERE notice_no = #{notice_no}
    </select>

    <insert id="addNotice" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO notice (notice_title, content, reg_date) VALUES (#{notice_title}, #{content}, NOW())
    </insert>

    <update id="updateNotice">
        UPDATE notice SET notice_title = #{notice_title}, content = #{content} WHERE notice_no = #{notice_no}
    </update>

    <delete id="deleteNotice">
        DELETE FROM notice WHERE notice_no = #{notice_no}
    </delete>


</mapper>